{
  "categories": [
    "engagement",
    "comments"
  ],
  "description": "Batches comments together, sends an in-app notification, waits 5 minutes, then sends an email digest",
  "name": "Batched comments",
  "steps": [
    {
      "description": "Collect comments for 5 minutes before sending notifications",
      "name": "Batch comments",
      "ref": "batch_comments",
      "settings": {
        "batch_execution_mode": "accumulate",
        "batch_key": "data.content_id",
        "batch_order": "asc",
        "batch_window": {
          "unit": "minutes",
          "value": 5
        },
        "batch_window_type": "fixed"
      },
      "type": "batch"
    },
    {
      "channel_key": "in-app",
      "channel_type": "in_app_feed",
      "name": "In-app notification",
      "ref": "in_app_1",
      "template": {
        "action_url": "{{ data.content_url | default: '' }}",
        "markdown_body@": "in_app_1/markdown_body.md"
      },
      "type": "channel"
    },
    {
      "description": "Wait before sending email digest",
      "name": "Wait 5 minutes",
      "ref": "delay_5min",
      "settings": {
        "delay_for": {
          "unit": "minutes",
          "value": 5
        }
      },
      "type": "delay"
    },
    {
      "channel_key": "knock-email",
      "channel_type": "email",
      "name": "Comment digest email",
      "ref": "email_1",
      "template": {
        "settings": {
          "attachment_key": "attachments",
          "layout_key": "default"
        },
        "subject": "{% if total_activities > 1 %}You have {{ total_activities }} new comments{% else %}You have a new comment{% endif %}",
        "visual_blocks@": "email_1/visual_blocks.json"
      },
      "type": "channel"
    }
  ],
  "trigger_data_json_schema": {
    "properties": {
      "content_id": {
        "description": "ID of the content being commented on (used for batch grouping)",
        "type": "string"
      },
      "content_title": {
        "description": "Title of the content for display in notifications",
        "type": "string"
      },
      "content_url": {
        "description": "URL to view the content",
        "format": "uri",
        "type": "string"
      }
    },
    "required": [
      "content_id"
    ],
    "type": "object"
  },
  "trigger_frequency": "every_trigger",
  "__readonly": {
    "environment": "development",
    "key": "batched-comments",
    "active": true,
    "valid": true,
    "created_at": "2026-02-16T16:41:05.869903Z"
  },
  "$schema": "https://schemas.knock.app/cli/workflow.json"
}
